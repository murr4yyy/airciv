{
  "manifest_version": 3,
  "name": "Aircív",
  "version": "1.0",
  "description": "Redirects paywalled news articles to the current page to an unpaywalled, archive.ph version with a single click.",
  "permissions": [
    "activeTab"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Archive this page"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}